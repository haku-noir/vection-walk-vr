install.packages("tidyverse")
install.packages("patchwork")
install.packages("openxlsx")
install.packages("stringr")
install.packages("lubridate")
install.packages("rpart")
install.packages("readxl")
library(readxl)
setwd("C:/Unity Project Data/Study/Assets/ResultData/mainwalk/output/output_folder")
knitr::opts_chunk$set(echo = TRUE)
library(ggplot2)
library(readxl)
library(tidyr)
# Excelファイルのパス
file_path <- "going_shiroyama_output.xlsx"
# 1枚目のシートを指定してデータを読み込む
data <- read_excel(file_path, sheet = 1)
View(data)
View(data)
# データをlong形式に変換
data_long <- data %>%
pivot_longer(cols = -1, names_to = "Trial", values_to = "Value")
# 条件名の列名を"Condition"に変更
names(data_long)[1] <- "Condition"
View(data_long)
# データの形状を長形式に変換
long_data <- pivot_longer(data,
cols = starts_with("試行"),
names_to = "試行番号",
values_to = "値")
# データの形状を長形式に変換
long_data <- pivot_longer(data,
cols = -1,
names_to = "試行番号",
values_to = "値")
View(long_data)
# データをlong形式に変換
data_long <- data %>%
pivot_longer(cols = starts_with("Trial"), names_to = "Trial", values_to = "Value")
data <- cbind(Trial = trial_numbers, data)
# 試行数の列を挿入
trial_numbers <- 1:10
data <- cbind(Trial = trial_numbers, data)
data <- cbind(試行数 = c("試行数", trial_numbers), data)
View(data)
# 1枚目のシートを指定してデータを読み込む
data <- read_excel(file_path, sheet = 1, range = "A1:K11")
# 1枚目のシートを指定してデータを読み込む
data <- read_excel(file_path, sheet = 1, range = "A1:H11")
data <- cbind(Trial = trial_numbers, data)
# データをlong形式に変換
data_long <- data %>%
pivot_longer(cols = -Trial, names_to = "Condition", values_to = "Value")
# プロットの作成
ggplot(data_long, aes(x = Trial, y = Value, color = Condition, group = Condition)) +
geom_line() +
geom_point() +
labs(title = "Condition-wise Trial Values Transition",
x = "Trial",
y = "Value") +
theme_minimal()
# プロットの作成
ggplot(data_long, aes(x = Trial, y = Value, color = Condition, group = Condition)) +
geom_line() +
geom_point() +
labs(title = "Condition-wise Trial Values Transition",
x = "Trial",
y = "Value") +
theme_minimal()+
scale_x_continuous(breaks = seq(1, 10, by = 1))
# プロットの作成
ggplot(data_long, aes(x = Trial, y = Value, color = Condition, group = Condition)) +
geom_line() +
geom_point() +
labs(title = "Condition-wise Trial Values Transition",
x = "Trial",
y = "Value") +
theme_minimal()+
scale_x_continuous(breaks = seq(1, 10, by = 1), minor_breaks = NULL)
# データの整形
data_long <- data_long %>%
mutate(Condition = factor(Condition, levels = unique(data_long$Condition))) # 条件を因子型として扱う
library(dplyr)
# データの整形
data_long <- data_long %>%
mutate(Condition = factor(Condition, levels = unique(data_long$Condition))) # 条件を因子型として扱う
# 平均値と標準偏差の計算
summary_data <- data_long %>%
group_by(Condition, Trial) %>%
summarise(mean_value = mean(Value), sd_value = sd(Value))
# プロットの作成
ggplot(data_long, aes(x = Trial, y = Value, color = Condition)) +
geom_line(alpha = 0.5) +  # 試行ごとの値をプロット
geom_point(alpha = 0.5) +
geom_line(data = summary_data, aes(y = mean_value), color = "black", size = 1) +  # 平均値のプロット
geom_errorbar(data = summary_data, aes(ymin = mean_value - sd_value, ymax = mean_value + sd_value), width = 0.1) +  # 標準偏差のプロット
labs(title = "Condition-wise Trial Values Transition",
x = "Trial",
y = "Value") +
theme_minimal()
View(summary_data)
# 平均値と標準偏差の計算
summary_data <- data_long %>%
group_by(Condition, Trial) %>%
summarise(mean_value = mean(Value), sd_value = sd(Value))
# 平均値と標準偏差の計算
summary_data <- data_long %>%
group_by(Condition) %>%
summarise(mean_value = mean(Value), sd_value = sd(Value))
# 欠損値を含む行を削除
data_long <- data_long[complete.cases(data_long$Value), ]
# 平均値と標準偏差の計算
summary_data <- data_long %>%
group_by(Condition) %>%
summarise(mean_value = mean(Value), sd_value = sd(Value))
# 外れ値を除外
data_long_filtered <- data_long %>%
left_join(summary_data, by = "Condition") %>%
filter(abs(Value - mean_value) <= 2 * sd_value)
# 試行数の列を挿入
trial_numbers <- 1:10
data <- cbind(Trial = trial_numbers, data)
# データをlong形式に変換
data_long <- data %>%
pivot_longer(cols = -Trial, names_to = "Condition", values_to = "Value")
# 欠損値を含む行を削除
data_long <- data_long[complete.cases(data_long$Value), ]
# 条件名の列名を"Condition"に変更
names(data_long)[1] <- "Condition"
# プロットの作成
ggplot(data_long, aes(x = Trial, y = Value, color = Condition, group = Condition)) +
geom_line() +
geom_point() +
labs(title = "Condition-wise Trial Values Transition",
x = "Trial",
y = "Value") +
theme_minimal()+
scale_x_continuous(breaks = seq(1, 10, by = 1), minor_breaks = NULL)
